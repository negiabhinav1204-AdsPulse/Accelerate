# Cloud Run env vars — copy to env.yaml and fill in values.
# env.yaml is gitignored; it's passed to Cloud Run at deploy time.
#
# DO NOT commit env.yaml with real secrets.

# ── LLM API Keys ──────────────────────────────────────────────────
ANTHROPIC_API_KEY: "sk-ant-..."
OPENAI_API_KEY: "sk-..."
GOOGLE_API_KEY: "..."

# ── LangGraph Checkpointer (Neon Postgres) ────────────────────────
# Use the same Neon DB as Accelerate, or a separate one.
# Must be a direct (non-pooler) URL for DDL operations.
DB_HOST: "ep-cool-fog-a1trynq0.ap-southeast-1.aws.neon.tech"
DB_PORT: "5432"
DB_USER: "neondb_owner"
DB_PASSWORD: "..."
DB_NAME: "langgraph_checkpoints"
DB_SSLMODE: "require"

# ── Accelerate Internal Tools Proxy ───────────────────────────────
# Accelerate's Vercel URL — the agentic service calls this to run
# Prisma-backed data tools (analytics, campaigns, ecommerce, etc.)
ACCELERATE_INTERNAL_URL: "https://accelerate-dashboard-sable.vercel.app"
INTERNAL_API_KEY: "generate-with: openssl rand -hex 32"

# ── GCS (generated image storage) ─────────────────────────────────
GCS_BUCKET_NAME: "accelerate-ai-assets"
GCS_CDN_BASE_URL: "https://storage.googleapis.com/accelerate-ai-assets"
GCS_PATH_PREFIX: "generated"

# ── Observability ─────────────────────────────────────────────────
SENTRY_DSN: ""                    # optional
LANGFUSE_SECRET_KEY: ""           # optional
LANGFUSE_PUBLIC_KEY: ""           # optional
LANGFUSE_ENABLED: "false"

# ── Uvicorn workers ───────────────────────────────────────────────
# Cloud Run: 1 worker per container (Cloud Run handles scaling via instances)
UVICORN_WORKERS: "1"

# ── Agent model overrides (optional) ─────────────────────────────
# Defaults are set in core/config.py — only override if needed.
# CAMPAIGN_AGENT_MODEL: "sonnet"
# WORKFLOW_PLAN_MODEL: "gpt-pro"
# WORKFLOW_BUILD_MODEL: "gpt-pro"
# IMAGE_GEN_MODEL: "gemini-preview"
