  feedProducts   FeedProduct[]
  feedTransformRules FeedTransformRule[]
  promotions     MerchantPromotion[]
  storeLocations StoreLocation[]
  commerceMarkets CommerceMarket[]
  deliveryRules  DeliverySpeedRule[]
