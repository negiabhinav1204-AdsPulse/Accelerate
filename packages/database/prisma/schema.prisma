  steps          JourneyStep[]
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model JourneyStep {
  id        String  @id @default(uuid()) @db.Uuid
  journeyId String  @db.Uuid
  order     Int
  type      String
  name      String
  config    Json
  journey   Journey @relation(fields: [journeyId], references: [id], onDelete: Cascade)
}

model KeywordResearch {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  name           String
  seedKeywords   String[]
  results        Json
  clusters       Json         @default("[]")
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// ---- Contextual Memory (self-learning vector store) ---- //

model OrgMemoryNode {
  id          String    @id @default(uuid()) @db.Uuid
  orgId       String    @db.Uuid
  userId      String?   @db.Uuid
  type        String    @db.VarChar(64)
  key         String    @db.VarChar(512)
  summary     String    @db.Text
  content     Json
  embedding   Unsupported("vector(768)")?
  confidence  Float     @default(1.0)
  accessCount Int       @default(0)
  sourceUrl   String?   @db.VarChar(2048)
  archivedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([orgId, userId, type, key], name: "memory_node_unique")
  @@index([orgId, type])
  @@index([orgId, userId, type])
  @@map("OrgMemoryNode")
}
