// ---- Commerce Layer ---- //

model CommerceConnector {
  id             String              @id @default(uuid()) @db.Uuid
  organizationId String              @db.Uuid
  platform       CommercePlatform
  name           String
  credentials    Json                // AES-256 encrypted: {store_url, access_token, api_key, etc.}
