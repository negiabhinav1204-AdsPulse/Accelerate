# ============================================================
# InMobi Accelerate — Environment Variables Template
# Copy this to .env and fill in your values.
# ============================================================

# ── LLM Keys ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Stripe ────────────────────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# ── SendGrid ──────────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=InMobi Accelerate

# ── Database (local Docker) ──────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=accelerate
POSTGRES_USER=accelerate_user
POSTGRES_PASSWORD=

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Google OAuth (for SSO) ───────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ── GCP ───────────────────────────────────────────────────────
GCP_PROJECT_ID=
GCP_REGION=asia-south1
BIGQUERY_DATASET=accelerate_analytics
GCS_BUCKET=accelerate-assets

# ── Ad Platforms ─────────────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
META_APP_ID=
META_APP_SECRET=
BING_CLIENT_ID=
BING_CLIENT_SECRET=

# ── App ───────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
